---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative">
  <div class="mx-auto max-w-6xl px-6 lg:px-10 py-16 md:py-24 lg:py-32">
    <p class="eyebrow vlek-rise">{t('hero.eyebrow')}</p>

    <h1 class="font-display mt-6 text-5xl md:text-7xl lg:text-8xl">
      <span class="block text-[color:var(--color-brand-ink)] vlek-rise vlek-rise-delay-1">
        {t('hero.title1')}
      </span>
      <span class="block text-[color:var(--color-brand-blue)] vlek-rise vlek-rise-delay-2">
        {t('hero.title2')}
      </span>
    </h1>

    <p class="mt-6 max-w-xl text-base md:text-lg text-[color:var(--color-brand-ink)]/85 vlek-rise vlek-rise-delay-3">
      {t('hero.body')}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-3 vlek-rise vlek-rise-delay-3">
      <a href={localizedPath(lang, '/contact')} class="btn-primary">
        {t('hero.cta.primary')} <span aria-hidden="true">→</span>
      </a>
      <a href={localizedPath(lang, '/#diensten')} class="btn-secondary">
        {t('hero.cta.secondary')}
      </a>
    </div>
  </div>
</section>
