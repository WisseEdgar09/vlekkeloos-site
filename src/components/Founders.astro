---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { Image } from 'astro:assets';
import founder1 from '../assets/founder-1.jpg';
import founder2 from '../assets/founder-2.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: t('founders.stat1.value'), label: t('founders.stat1.label') },
  { value: t('founders.stat2.value'), label: t('founders.stat2.label') },
  { value: t('founders.stat3.value'), label: t('founders.stat3.label') },
];
---

<section id="over-ons" class="bg-[color:var(--color-brand-tint)]">
  <div class="mx-auto max-w-6xl px-6 lg:px-10 py-16 md:py-24">
    <div class="grid gap-10 md:gap-16 md:grid-cols-2 items-center">
      <div>
        <p class="eyebrow">{t('founders.eyebrow')}</p>
        <h2 class="font-display mt-4 text-3xl md:text-4xl lg:text-5xl text-[color:var(--color-brand-ink)]">
          {t('founders.title')}
        </h2>
        <p class="mt-5 max-w-md text-[color:var(--color-brand-ink)]/85">
          {t('founders.body')}
        </p>

        <dl class="mt-10 grid grid-cols-3 gap-4 max-w-md">
          {
            stats.map((s) => (
              <div>
                <dt class="font-display text-3xl text-[color:var(--color-brand-blue)]">
                  {s.value}
                </dt>
                <dd class="mt-1 text-xs text-[color:var(--color-brand-ink)]/75">
                  {s.label}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="grid grid-cols-2 gap-3 md:gap-4">
        <figure class="relative aspect-[3/4] rounded-[12px] overflow-hidden">
          <Image src={founder1} alt={`Rick Kops, ${t('founders.role').toLowerCase()} van Vlekkeloos`} width={900} height={1200} class="w-full h-full object-cover" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-3 py-3 text-white">
            <span class="block text-sm font-medium leading-tight">Rick Kops</span>
            <span class="block text-xs text-white/80">{t('founders.role')}</span>
          </figcaption>
        </figure>
        <figure class="relative aspect-[3/4] rounded-[12px] overflow-hidden mt-6 md:mt-10">
          <Image src={founder2} alt={`Wisse Seunnenga, ${t('founders.role').toLowerCase()} van Vlekkeloos`} width={900} height={1200} class="w-full h-full object-cover" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-3 py-3 text-white">
            <span class="block text-sm font-medium leading-tight">Wisse Seunnenga</span>
            <span class="block text-xs text-white/80">{t('founders.role')}</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
