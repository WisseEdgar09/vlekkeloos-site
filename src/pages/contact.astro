---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title="Contact · Vlekkeloos">
  <section>
    <div class="mx-auto max-w-3xl px-6 lg:px-10 py-16 md:py-24">
      <p class="eyebrow">{t('nav.contact')}</p>
      <h1 class="font-display mt-4 text-4xl md:text-5xl lg:text-6xl">
        {t('contact.title')}
      </h1>
      <p class="mt-6 text-[color:var(--color-brand-ink)]/85 max-w-xl">
        {t('contact.body')}
      </p>

      <form
        action="https://formspree.io/f/mykazrbb"
        method="POST"
        class="mt-12 grid gap-6"
      >

        <div class="grid md:grid-cols-2 gap-6">
          <div class="grid gap-2">
            <label for="name" class="text-sm font-medium">{t('contact.name')}</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            />
          </div>
          <div class="grid gap-2">
            <label for="company" class="text-sm font-medium">{t('contact.company')}</label>
            <input
              id="company"
              name="company"
              type="text"
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="grid gap-2">
            <label for="email" class="text-sm font-medium">{t('contact.email')}</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            />
          </div>
          <div class="grid gap-2">
            <label for="phone" class="text-sm font-medium">{t('contact.phone')}</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="grid gap-2">
            <label for="type" class="text-sm font-medium">{t('contact.type')}</label>
            <select
              id="type"
              name="type"
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            >
              <option value="municipality">{t('contact.type.municipality')}</option>
              <option value="business">{t('contact.type.business')}</option>
              <option value="private">{t('contact.type.private')}</option>
            </select>
          </div>
          <div class="grid gap-2">
            <label for="location" class="text-sm font-medium">{t('contact.location')}</label>
            <input
              id="location"
              name="location"
              type="text"
              class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition"
            />
          </div>
        </div>

        <div class="grid gap-2">
          <label for="message" class="text-sm font-medium">{t('contact.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="px-4 py-3 rounded-[10px] bg-white border border-[color:var(--color-brand-line)] focus:border-[color:var(--color-brand-blue)] outline-none transition resize-y"
          ></textarea>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-2">
          <p class="text-xs text-[color:var(--color-brand-muted)] max-w-md">
            {t('contact.privacy')}
          </p>
          <button type="submit" class="btn-primary">
            {t('contact.submit')} <span aria-hidden="true">→</span>
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
